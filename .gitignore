# ─── OS / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
# ─── Flutter / Dart  (Details: mobile/.gitignore) ────────────────────────────
mobile/.dart_tool/
mobile/build/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.pub-cache/
mobile/.pub/
mobile/coverage/

# ─── Angular Web  (Details: web/.gitignore) ───────────────────────────────────
web/node_modules/
web/dist/
web/.angular/
web/.sass-cache/
web/coverage/

# ─── VS Code (nur lokale Session-Dateien ausschließen) ───────────────────────
.vscode/settings.local.json

# ─── Claude Code (local session state) ───────────────────────────────────────
.claude/settings.local.json
.claude/.fuse_hidden*

# ─── Planungs-Dokumente (Claude-intern, nicht für VCS) ────────────────────────
web/thoughts/

# ─── Secrets ──────────────────────────────────────────────────────────────────
web/src/environments/environment.prod.ts
web/src/environments/environment.local.ts
mobile/android/key.properties
mobile/android/local.properties
