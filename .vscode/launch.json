{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Angular: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/web/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${workspaceFolder}/web/src/*"
      },
      "preLaunchTask": "ng serve"
    },
    {
      "name": "▶ Angular: Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/web/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${workspaceFolder}/web/src/*"
      },
      "preLaunchTask": "ng serve"
    },
    {
      "name": "🔗 Angular: Attach (laufender Server)",
      "type": "chrome",
      "request": "attach",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/web/src"
    }
  ]
}
