# Domain anpassen — Caddy holt automatisch ein Let's Encrypt Zertifikat
work-time-manager.app {
    reverse_proxy web:80

    # Logs
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# www-Redirect
www.work-time-manager.app {
    redir https://work-time-manager.app{uri} permanent
}
